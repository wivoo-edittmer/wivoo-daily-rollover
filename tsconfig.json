{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2018",
        "allowImportingTsExtensions": true,
        "moduleResolution": "bundler",
        "isolatedModules": true,
        "strictNullChecks": true,
        "noEmit": true
    },
    "include": ["src/**/*.ts"]
}
